<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF6EE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kumbara-Kala"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#B5451B"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="State Pride - Clay Artisan Branding"
            android:textSize="14sp"
            android:textColor="#7A2E0E"
            android:gravity="center"
            android:paddingBottom="30dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your Name"
            android:textColor="#7A2E0E"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingBottom="6dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your name"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Village / Town"
            android:textColor="#7A2E0E"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingBottom="6dp"/>

        <EditText
            android:id="@+id/etVillage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your village or town"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textColor="#7A2E0E"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingBottom="6dp"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your phone number"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:textSize="15sp"
            android:inputType="phone"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Craft Generation"
            android:textColor="#7A2E0E"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingBottom="6dp"/>

        <EditText
            android:id="@+id/etGeneration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 2nd Generation Potter"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:textSize="15sp"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save and Continue"
            android:backgroundTint="#B5451B"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="14dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGoToCatalog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go to Catalog"
            android:backgroundTint="#5C6B2E"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="14dp"/>

    </LinearLayout>
</ScrollView>